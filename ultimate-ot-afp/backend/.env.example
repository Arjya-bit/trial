# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-in-production-use-strong-key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database - PostgreSQL
POSTGRES_USER=otafp_user
POSTGRES_PASSWORD=otafp_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=otafp_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

# Kaggle API (for AI model downloads)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# AI Model Settings
AI_MODEL_PATH=./models
AI_MODEL_DATASET=lakshmi25npathi/cybersecurity-incidents

# C2 Settings
C2_PORT=8443
C2_SSL_CERT=./certs/cert.pem
C2_SSL_KEY=./certs/key.pem

# Forensics
FORENSICS_STORAGE_PATH=./forensics_data
MAX_UPLOAD_SIZE=5368709120

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
