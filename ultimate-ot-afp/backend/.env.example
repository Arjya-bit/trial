# Environment Configuration for Ultimate OT-AFP Platform

# Application Settings
APP_NAME=Ultimate OT-AFP Platform
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Database Configuration
DATABASE_URL=sqlite:///./ultimate_ot_afp.db
# For PostgreSQL: postgresql://user:password@localhost:5432/ultimate_ot_afp
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# AI Model Configuration
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
AI_MODEL_PATH=./models
DEFAULT_AI_MODEL=microsoft/DialoGPT-medium

# C2 Configuration
C2_PORT=8443
C2_SSL_CERT=
C2_SSL_KEY=

# Stealth Configuration
STEALTH_MODE=true
PROCESS_HIDE_LIST=["ultimate-ot-afp", "python", "forensics"]

# Autonomous Operations
AUTO_EXECUTION=false
AUTO_PERSISTENCE=false
AUTO_STEALTH=true

# Forensics Configuration
EVIDENCE_PATH=./evidence
CASE_PATH=./cases
TEMP_PATH=./temp

# Network Configuration
PCAP_INTERFACE=eth0
PCAP_BUFFER_SIZE=1048576

# OT Security Configuration
MODBUS_PORT=502
OPC_UA_PORT=4840
DNP3_PORT=20000

# Monitoring
LOG_LEVEL=INFO
LOG_FILE=./logs/ultimate_ot_afp.log
METRICS_ENABLED=true

# Performance
MAX_WORKERS=4
CHUNK_SIZE=8192
CACHE_TTL=3600