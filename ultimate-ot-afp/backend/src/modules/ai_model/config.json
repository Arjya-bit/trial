{
  "model_config": {
    "default_model": "cybersecurity_incidents",
    "model_path": "./models",
    "auto_download": true,
    "update_interval_days": 7
  },
  "inference_config": {
    "batch_size": 32,
    "confidence_threshold": 0.7,
    "enable_caching": true,
    "cache_ttl_seconds": 3600
  },
  "training_config": {
    "default_model_type": "random_forest",
    "test_size": 0.2,
    "cross_validation_folds": 5,
    "hyperparameter_tuning": true
  },
  "supported_models": {
    "intrusion_detection": {
      "dataset": "sampadab17/network-intrusion-detection",
      "type": "classification",
      "features": ["protocol", "service", "flag", "src_bytes", "dst_bytes"],
      "target": "attack_type"
    },
    "malware_detection": {
      "dataset": "Cornell-University/malware-detection",
      "type": "classification",
      "features": ["file_size", "entropy", "api_calls", "network_activity"],
      "target": "malware_family"
    },
    "network_traffic": {
      "dataset": "jsrojas/ip-network-traffic-flows-labeled-with-87-apps",
      "type": "classification",
      "features": ["flow_duration", "packets", "bytes", "ports"],
      "target": "application"
    }
  },
  "kaggle_datasets": {
    "recommended": [
      "lakshmi25npathi/cybersecurity-incidents",
      "sampadab17/network-intrusion-detection",
      "shashwatwork/web-page-phishing-detection-dataset"
    ]
  }
}
